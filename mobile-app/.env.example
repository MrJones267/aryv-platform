# Environment Configuration for Hitch Mobile App

# API Configuration
API_BASE_URL=http://localhost:3001
SOCKET_URL=http://localhost:3001

# Feature Flags
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_CRASH_REPORTING=true

# Google Services Configuration
GOOGLE_WEB_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
GOOGLE_GEOCODING_API_KEY=your_google_geocoding_api_key_here

# Firebase Configuration
# Download google-services.json (Android) and GoogleService-Info.plist (iOS) from Firebase Console
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_MESSAGING_SENDER_ID=your-firebase-sender-id
FIREBASE_APP_ID=1:123456789:android:abcdef123456

# Third-party Services
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
SENTRY_DSN=your_sentry_dsn_here

# OTP Service Configuration
# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token  
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Hitch Support

# OTP Settings
OTP_CODE_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_COOLDOWN_SECONDS=60

# App Configuration
APP_NAME=Hitch
BUNDLE_ID=com.hitch.mobile
VERSION_CODE=1
VERSION_NAME=1.0.0

# Development/Testing
ENABLE_DEV_TOOLS=true
ENABLE_MOCK_SERVICES=false